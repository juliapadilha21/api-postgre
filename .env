# Este arquivo é vital para a segurança e portabilidade do software
# Ele evita que dados sensíveis (senhas) fiquem "explícitos" no código-fonte

# Porta onde o servidor Express será executado localmente
PORT=3000

# String de Conexão: Segue o padrão protocolo://usuario:senha@host:porta/database
# É fundamental não versionar este arquivo em sistemas reais (usar .gitignore)
CONNECTION_STRING=postgresql://postgres:12345678@localhost:5432/COMPLIANCE